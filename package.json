{
  "name": "claude-session-manager",
  "description": "Local manager for Claude CLI sessions, reading the *.jsonl files under ~/.claude/projects.",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "server"
  ],
  "resolutions": {
    "shell-quote": "^1.10.0",
    "@radix-ui/react-tooltip": "1.2.13",
    "lucide-react": "1.25.0",
    "lint-staged": "17.1.0",
    "typescript-eslint": "8.64.0",
    "@vitejs/plugin-react": "6.0.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "prettier": "3.9.5"
  },
  "scripts": {
    "dev": "concurrently -n web,server -c blue,green \"vite\" \"yarn workspace server run dev\"",
    "build": "tsc -b && vite build && yarn workspace server run build",
    "lint": "eslint . && yarn workspace server run lint",
    "lint:fix": "eslint . && yarn workspace server run lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b --noEmit",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint"
  },
  "dependencies": {
    "@radix-ui/react-tooltip": "^1.2.14",
    "@tailwindcss/vite": "^4.3.3",
    "axios": "^1.18.1",
    "lucide-react": "^1.26.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.2.0",
    "prettier": "^3.9.6",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1"
  },
  "packageManager": "yarn@4.17.1+sha512.ccbfabf7d7b6b32075088be9386fb9a2e00bb6887ef07fa56effabc890a56d53da1ccc4128d62db245fcbd3961b236d75335bdf7d5320ed6eafb7588b7ad4697"
}
